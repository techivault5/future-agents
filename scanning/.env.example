# ============================================================
# Snowflake credentials — copy to .env and fill in your values
# NEVER commit the .env file to version control
# ============================================================
SNOWFLAKE_ACCOUNT=your-account-identifier   # e.g. xy12345.us-east-1
SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_DATABASE=FUTURE_AGENTS_DB
SNOWFLAKE_SCHEMA=KNOWLEDGE
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_ROLE=                             # leave blank to use default role

# Optional: private key auth (comment out SNOWFLAKE_PASSWORD if using this)
# SNOWFLAKE_PRIVATE_KEY_PATH=/path/to/rsa_key.p8

# ============================================================
# Crawler tuning
# ============================================================
CRAWLER_MAX_DEPTH=3          # how many hops from the seed URL
CRAWLER_MAX_PAGES=500        # hard cap per crawl session
CRAWLER_CONCURRENCY=5        # parallel HTTP requests
CRAWLER_REQUEST_DELAY=1.0    # seconds between requests to the same domain
CRAWLER_TIMEOUT=15           # HTTP timeout in seconds
CRAWLER_STAY_ON_DOMAIN=true  # only follow links on the same domain as the seed
CRAWLER_RESPECT_ROBOTS=true  # honour robots.txt

# ============================================================
# Snowflake write settings
# ============================================================
SNOWFLAKE_BATCH_SIZE=50      # pages per Snowflake batch insert
