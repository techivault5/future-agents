{
  "name": "my-node-service",
  "version": "0.1.0",
  "description": "Node microservice — fill in your description",
  "main": "dist/index.js",
  "scripts": {
    "build":   "tsc",
    "start":   "node dist/index.js",
    "dev":     "ts-node-dev --respawn src/index.ts",
    "test":    "jest --coverage",
    "lint":    "eslint 'src/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "guardrails": "python3 ../../guardrails/guardrails_engine.py . --mode check"
  },
  "dependencies": {
    "express":          "^4.19.0",
    "cors":             "^2.8.5",
    "helmet":           "^7.1.0",
    "dotenv":           "^16.4.0",
    "zod":              "^3.23.0",
    "winston":          "^3.13.0",
    "pg":               "^8.12.0",
    "ioredis":          "^5.4.0",
    "jsonwebtoken":     "^9.0.0",
    "bcryptjs":         "^2.4.3",
    "uuid":             "^10.0.0"
  },
  "devDependencies": {
    "@types/express":       "^4.17.0",
    "@types/node":          "^20.14.0",
    "@types/jest":          "^29.5.0",
    "@types/jsonwebtoken":  "^9.0.0",
    "@types/bcryptjs":      "^2.4.0",
    "typescript":           "^5.5.0",
    "ts-node-dev":          "^2.0.0",
    "jest":                 "^29.7.0",
    "ts-jest":              "^29.2.0",
    "eslint":               "^9.5.0",
    "supertest":            "^7.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm":  ">=10.0.0"
  }
}
