# ML Project Environment Template
APP_ENV=development
LOG_LEVEL=INFO

# Data Storage
DATA_BUCKET=REPLACE_ME
MODEL_BUCKET=REPLACE_ME

# MLflow / Experiment Tracking
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=my-experiment

# Feature Store
FEAST_FEATURE_STORE_URL=REPLACE_ME

# Cloud
AWS_ACCESS_KEY_ID=REPLACE_ME
AWS_SECRET_ACCESS_KEY=REPLACE_ME
AWS_DEFAULT_REGION=us-east-1

# Model Serving
SERVING_HOST=0.0.0.0
SERVING_PORT=8080

# Weights & Biases
WANDB_API_KEY=REPLACE_ME
WANDB_PROJECT=my-ml-project
