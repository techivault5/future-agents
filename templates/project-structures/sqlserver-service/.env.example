# SQL Server Service — Environment Template
# Copy to .env — NEVER commit .env

# SQL Server connection (ADO.NET format)
# Use Windows Auth in production where possible (no password needed)
MSSQL_SERVER=localhost
MSSQL_PORT=1433
MSSQL_DATABASE=REPLACE_ME
MSSQL_USER=REPLACE_ME
MSSQL_SA_PASSWORD=REPLACE_ME

# ADO.NET style (alternative — pick one)
# MSSQL_CONNECTION_STRING=Server=localhost,1433;Database=mydb;User Id=sa;Password=REPLACE_ME;Encrypt=True;TrustServerCertificate=False;

# SQLAlchemy (Python) — uses mssql+pyodbc driver
# DATABASE_URL=mssql+pyodbc://sa:REPLACE_ME@localhost:1433/mydb?driver=ODBC+Driver+18+for+SQL+Server

# Entity Framework (C#) — use secrets.json or User Secrets, NOT appsettings.json
# ASPNETCORE_ENVIRONMENT=Development

# Azure SQL (production)
AZURE_SQL_SERVER=REPLACE_ME.database.windows.net
AZURE_SQL_DATABASE=REPLACE_ME
AZURE_CLIENT_ID=REPLACE_ME
AZURE_CLIENT_SECRET=REPLACE_ME
AZURE_TENANT_ID=REPLACE_ME

# App
APP_ENV=development
LOG_LEVEL=INFO
