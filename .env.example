# ═══════════════════════════════════════════════════════════════
# IT Agents Guardrails — Environment Template
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# NEVER commit .env — it is in .gitignore
# ALWAYS commit .env.example with REPLACE_ME placeholders
# ═══════════════════════════════════════════════════════════════

# ── Container / Compose ─────────────────────────────────────────
# Path on your HOST machine to mount as /workspace for scanning.
# Default is current directory (.) — override to scan another project.
WORKSPACE_PATH=.

# Default guardrails mode: check | fix | block
GUARDRAILS_MODE=check

# ── Platform ────────────────────────────────────────────────────
PLATFORM_ENV=development
PLATFORM_REGION=us-east-1

# ── Human Escalation (optional) ─────────────────────────────────
# Slack incoming webhook — receive escalation alerts in a channel
GUARDRAILS_SLACK_WEBHOOK=REPLACE_ME

# Generic webhook (e.g. Teams, PagerDuty, custom endpoint)
GUARDRAILS_WEBHOOK_URL=REPLACE_ME

# ── Agent Registry (optional overrides) ─────────────────────────
# Leave blank to use defaults from config/connective_config.yaml
AGENTS_PATH=agents/
AGENTS_CACHE_TTL_SECS=3600

# ── Guardrails profile ──────────────────────────────────────────
# standard | strict | relaxed | architect
# Overrides active_profile in config/guardrails_config.yaml
GUARDRAILS_PROFILE=standard

# ── CI/CD ────────────────────────────────────────────────────────
# Set to 'true' to treat warnings as errors in block mode
GUARDRAILS_STRICT_WARNINGS=false
